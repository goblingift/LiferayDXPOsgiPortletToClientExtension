{
	"name": "contact-form-react",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"build": "esbuild src/index.js --outdir=build/static --bundle --entry-names=[name].[hash] --format=iife --loader:.js=jsx --loader:.css=css --minify",
		"build:dev": "esbuild src/index.js --outdir=build/static --bundle --entry-names=[name].[hash] --format=iife --loader:.js=jsx --loader:.css=css --sourcemap",
		"deploy": "sh deploy.sh",
		"build:deploy": "npm run build && npm run deploy"
	},
	"dependencies": {
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	},
	"devDependencies": {
		"esbuild": "^0.23.1"
	}
}
